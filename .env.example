APP_ENV=dev
LOG_LEVEL=INFO
TELEGRAM_BOT_TOKEN=put-your-telegram-bot-token
DATABASE_URL=postgresql+asyncpg://tryonlab:tryonlab@postgres:5432/tryonlab
REDIS_URL=redis://redis:6379/0

# Storage backend: local|s3
STORAGE_BACKEND=local
STORAGE_LOCAL_DIR=/app/storage
# Optional base URL for future public/proxied media endpoints
STORAGE_PUBLIC_BASE_URL=
SIGNED_URL_TTL_SECONDS=3600

# S3 / MinIO settings (required only when STORAGE_BACKEND=s3)
STORAGE_S3_ENDPOINT=http://minio:9000
STORAGE_S3_BUCKET=tryonlab
STORAGE_S3_ACCESS_KEY=minio
STORAGE_S3_SECRET_KEY=minio123
STORAGE_S3_REGION=us-east-1
STORAGE_S3_USE_SSL=false
# Optional custom public base URL for S3 objects (without query token)
STORAGE_S3_PUBLIC_BASE_URL=

# Optional MinIO bootstrap credentials (docker compose profile: storage)
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123


# Jobs API
RETENTION_HOURS=72
MAX_UPLOAD_MB=12
JOB_QUEUE_KEY=queue:jobs
JOB_STATUS_TTL_SECONDS=3600
